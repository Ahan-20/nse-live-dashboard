# Local-only credentials. Copy this file to `.env` and fill in your values.
# `.env` is git-ignored — it stays on your Mac only.
#
# This file is for the LOCAL workflow (intraday from your home IP). On Railway
# you set the same variables in the platform's Variables tab instead.

# Enable Groww-backed intraday (1H + 15m signals). Leave blank/omit to disable.
INTRADAY_PROVIDER=groww

# From groww.in → Trade APIs → API Keys → Generate TOTP token.
# The KEY is the long string shown at the top.
GROWW_API_KEY=

# The TOTP *secret* (Base32 string under the QR code, e.g. JBSWY3DPEHPK3PXP...).
# NOT the 6-digit code — that refreshes every 30s and the server generates it
# from this secret.
GROWW_API_SECRET=

# Optional: the public IP you whitelisted with Groww. If set, the server warns
# you on boot when your home IP has drifted (so Groww won't silently fail).
# Find yours at https://api.ipify.org
GROWW_REGISTERED_IP=
